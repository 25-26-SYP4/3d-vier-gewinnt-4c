<Window x:Class="_3D_Vier_Gewinnt_Server.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Robot Test – Bit-Eingabe" Width="500" Height="440"
        ResizeMode="NoResize">
    <StackPanel Margin="20">

        <!-- Befehlszähler -->
        <TextBlock Text="Befehlszähler" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <CheckBox x:Name="CbBz0" Content="Bit 0  (1)" Margin="0,0,24,0" VerticalContentAlignment="Center"/>
            <CheckBox x:Name="CbBz1" Content="Bit 1  (2)" Margin="0,0,24,0" VerticalContentAlignment="Center"/>
            <CheckBox x:Name="CbBz2" Content="Bit 2  (4)" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Entnahme -->
        <TextBlock Text="Entnahme" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <CheckBox x:Name="CbEnt" Content="EntnahmePos1  →  DI[111]" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Ablage -->
        <TextBlock Text="Ablage / Position" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <CheckBox x:Name="CbAbl0" Content="Bit 0  (1)" Margin="0,0,24,0" VerticalContentAlignment="Center"
                      Checked="Abl_Changed" Unchecked="Abl_Changed"/>
            <CheckBox x:Name="CbAbl1" Content="Bit 1  (2)" Margin="0,0,24,0" VerticalContentAlignment="Center"
                      Checked="Abl_Changed" Unchecked="Abl_Changed"/>
            <CheckBox x:Name="CbAbl2" Content="Bit 2  (4)" Margin="0,0,24,0" VerticalContentAlignment="Center"
                      Checked="Abl_Changed" Unchecked="Abl_Changed"/>
            <CheckBox x:Name="CbAbl3" Content="Bit 3  (8)" VerticalContentAlignment="Center"
                      Checked="Abl_Changed" Unchecked="Abl_Changed"/>
        </StackPanel>
        <TextBlock x:Name="TxAblageWert" Text="Position: 0  (0000b)" Foreground="Gray" Margin="0,2,0,20"/>

        <!-- Senden -->
        <Button Content="Senden" Click="BtnSend_Click"
                Width="110" Height="32" HorizontalAlignment="Left" Margin="0,0,0,14"/>

        <!-- Status -->
        <TextBlock Text="Gesendet:" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock x:Name="TxStatus" Text="–" FontFamily="Consolas" Margin="0,0,0,16"/>

        <!-- Feedback -->
        <Separator Margin="0,0,0,12"/>
        <TextBlock Text="Feedback vom Roboter (Schalter am Steckboard):"
                   FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock x:Name="TxFeedback" Text="–" FontFamily="Consolas" FontSize="13"/>

    </StackPanel>
</Window>
